# PM-RU Content Agent — Environment Variables
# Copy this file to .env and fill in your values

# ── Required for Figma rendering ──────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=figd_your_personal_access_token_here

# ── Optional: database (defaults to SQLite demo) ──────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_agent

# ── Optional: Redis / Celery (tasks run in-process without this) ──────────────
# REDIS_URL=redis://localhost:6379/0

# ── Optional: Redmine integration ────────────────────────────────────────────
# REDMINE_BASE_URL=https://project.pm.ru
# REDMINE_API_KEY=your_redmine_api_key

# ── Optional: S3-compatible storage ──────────────────────────────────────────
# STORAGE_ENDPOINT_URL=https://storage.yandexcloud.net
# STORAGE_BUCKET=pm-ru-content-slides
# AWS_ACCESS_KEY_ID=your_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ── Optional: OpenAI / LLM ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
